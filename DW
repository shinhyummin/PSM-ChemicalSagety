<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>화학물질 안전관리 시스템</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;500;700;900&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
<style>
  :root {
    --bg: #0a0e1a;
    --surface: #111827;
    --surface2: #1a2235;
    --border: #1f2d45;
    --accent: #f97316;
    --accent2: #fb923c;
    --blue: #3b82f6;
    --green: #22c55e;
    --yellow: #eab308;
    --red: #ef4444;
    --purple: #a855f7;
    --text: #e2e8f0;
    --text2: #94a3b8;
    --text3: #475569;
  }
  * { margin:0; padding:0; box-sizing:border-box; }
  body {
    font-family: 'Noto Sans KR', sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
  }

  /* HEADER */
  header {
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    padding: 0 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 60px;
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
    font-weight: 700;
    font-size: 15px;
    letter-spacing: -0.3px;
  }
  .logo-icon {
    width: 32px; height: 32px;
    background: var(--accent);
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    font-size: 16px;
  }
  .header-right { display: flex; gap: 8px; }
  .btn {
    padding: 7px 14px;
    border-radius: 8px;
    border: none;
    cursor: pointer;
    font-family: inherit;
    font-size: 13px;
    font-weight: 500;
    transition: all 0.15s;
  }
  .btn-primary { background: var(--accent); color: #fff; }
  .btn-primary:hover { background: var(--accent2); }
  .btn-ghost { background: transparent; color: var(--text2); border: 1px solid var(--border); }
  .btn-ghost:hover { background: var(--surface2); color: var(--text); }
  .btn-sm { padding: 5px 10px; font-size: 12px; }
  .btn-danger { background: #7f1d1d; color: #fca5a5; }
  .btn-danger:hover { background: #991b1b; }

  /* LAYOUT */
  .layout { display: flex; min-height: calc(100vh - 60px); }
  .sidebar {
    width: 220px;
    background: var(--surface);
    border-right: 1px solid var(--border);
    padding: 20px 12px;
    flex-shrink: 0;
  }
  @media(max-width:768px) {
    .sidebar { display: none; }
    .main { padding: 16px; }
  }
  .nav-item {
    display: flex; align-items: center; gap: 10px;
    padding: 9px 12px;
    border-radius: 8px;
    cursor: pointer;
    font-size: 13px;
    color: var(--text2);
    transition: all 0.15s;
    margin-bottom: 2px;
    border: none; background: transparent; width: 100%; text-align: left;
    font-family: inherit;
  }
  .nav-item:hover { background: var(--surface2); color: var(--text); }
  .nav-item.active { background: rgba(249,115,22,0.15); color: var(--accent); }
  .nav-label { font-size: 10px; font-weight: 600; color: var(--text3); text-transform: uppercase; letter-spacing: 1px; padding: 14px 12px 6px; }

  .main { flex: 1; padding: 28px 32px; }

  /* STATS */
  .stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 12px; margin-bottom: 28px; }
  .stat-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 16px;
  }
  .stat-label { font-size: 11px; color: var(--text3); font-weight: 500; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 6px; }
  .stat-value { font-size: 26px; font-weight: 700; font-family: 'JetBrains Mono', monospace; }
  .stat-sub { font-size: 11px; color: var(--text3); margin-top: 2px; }

  /* SECTION HEADER */
  .section-header {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 16px;
  }
  .section-title { font-size: 16px; font-weight: 700; }

  /* SEARCH & FILTER */
  .toolbar { display: flex; gap: 10px; margin-bottom: 20px; flex-wrap: wrap; }
  .search-wrap { position: relative; flex: 1; min-width: 200px; }
  .search-wrap input {
    width: 100%;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 9px;
    padding: 9px 12px 9px 36px;
    color: var(--text);
    font-family: inherit;
    font-size: 13px;
    outline: none;
    transition: border-color 0.15s;
  }
  .search-wrap input:focus { border-color: var(--accent); }
  .search-wrap input::placeholder { color: var(--text3); }
  .search-icon {
    position: absolute; left: 11px; top: 50%; transform: translateY(-50%);
    color: var(--text3); font-size: 14px;
  }
  .filter-btn {
    padding: 9px 14px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 9px;
    color: var(--text2);
    font-size: 12px;
    cursor: pointer;
    font-family: inherit;
    transition: all 0.15s;
    white-space: nowrap;
  }
  .filter-btn:hover, .filter-btn.active { border-color: var(--accent); color: var(--accent); background: rgba(249,115,22,0.08); }

  /* CHEMICAL TABLE */
  .table-wrap {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
  }
  table { width: 100%; border-collapse: collapse; }
  thead th {
    background: var(--surface2);
    padding: 11px 14px;
    text-align: left;
    font-size: 11px;
    font-weight: 600;
    color: var(--text3);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    border-bottom: 1px solid var(--border);
  }
  tbody tr { border-bottom: 1px solid var(--border); transition: background 0.1s; cursor: pointer; }
  tbody tr:last-child { border-bottom: none; }
  tbody tr:hover { background: var(--surface2); }
  tbody td { padding: 12px 14px; font-size: 13px; }

  /* RISK BADGE */
  .badge {
    display: inline-flex; align-items: center;
    padding: 3px 9px;
    border-radius: 99px;
    font-size: 11px;
    font-weight: 600;
  }
  .badge-1 { background: rgba(34,197,94,0.15); color: var(--green); }
  .badge-2 { background: rgba(234,179,8,0.15); color: var(--yellow); }
  .badge-3 { background: rgba(249,115,22,0.15); color: var(--accent); }
  .badge-4 { background: rgba(239,68,68,0.15); color: var(--red); }

  /* GHS ICONS */
  .ghs-icons { display: flex; gap: 4px; flex-wrap: wrap; }
  .ghs-icon {
    width: 24px; height: 24px;
    border-radius: 4px;
    display: flex; align-items: center; justify-content: center;
    font-size: 13px;
    background: var(--surface2);
    border: 1px solid var(--border);
    title: attr(data-title);
  }

  /* MODAL */
  .modal-backdrop {
    position: fixed; inset: 0;
    background: rgba(0,0,0,0.7);
    backdrop-filter: blur(4px);
    z-index: 200;
    display: flex; align-items: center; justify-content: center;
    padding: 20px;
    opacity: 0; pointer-events: none; transition: opacity 0.2s;
  }
  .modal-backdrop.open { opacity: 1; pointer-events: all; }
  .modal {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    width: 100%;
    max-width: 680px;
    max-height: 90vh;
    overflow-y: auto;
    transform: translateY(16px);
    transition: transform 0.2s;
  }
  .modal-backdrop.open .modal { transform: translateY(0); }
  .modal-header {
    padding: 20px 24px 16px;
    border-bottom: 1px solid var(--border);
    display: flex; align-items: center; justify-content: space-between;
    position: sticky; top: 0; background: var(--surface); z-index: 1;
  }
  .modal-title { font-size: 16px; font-weight: 700; }
  .modal-body { padding: 20px 24px; }
  .modal-footer { padding: 16px 24px; border-top: 1px solid var(--border); display: flex; justify-content: flex-end; gap: 8px; }
  .close-btn { background: none; border: none; color: var(--text3); font-size: 20px; cursor: pointer; padding: 4px; }
  .close-btn:hover { color: var(--text); }

  /* FORM */
  .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  @media(max-width:500px) { .form-grid { grid-template-columns: 1fr; } }
  .form-full { grid-column: 1 / -1; }
  .form-group { display: flex; flex-direction: column; gap: 6px; }
  .form-label { font-size: 12px; font-weight: 500; color: var(--text2); }
  .form-input, .form-select, .form-textarea {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 9px 12px;
    color: var(--text);
    font-family: inherit;
    font-size: 13px;
    outline: none;
    transition: border-color 0.15s;
  }
  .form-input:focus, .form-select:focus, .form-textarea:focus { border-color: var(--accent); }
  .form-select { appearance: none; }
  .form-textarea { resize: vertical; min-height: 72px; }

  /* GHS CHECKBOX */
  .ghs-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; }
  .ghs-check {
    display: flex; align-items: center; gap: 8px;
    padding: 8px 10px;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    cursor: pointer;
    font-size: 12px;
    transition: all 0.15s;
    user-select: none;
  }
  .ghs-check input { display: none; }
  .ghs-check.checked { border-color: var(--accent); background: rgba(249,115,22,0.08); color: var(--accent); }
  .ghs-check-icon { font-size: 18px; }

  /* DETAIL MODAL */
  .detail-section { margin-bottom: 20px; }
  .detail-section-title {
    font-size: 11px; font-weight: 600; color: var(--text3);
    text-transform: uppercase; letter-spacing: 0.8px;
    margin-bottom: 10px;
    padding-bottom: 6px;
    border-bottom: 1px solid var(--border);
  }
  .detail-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
  .detail-item { }
  .detail-item-label { font-size: 11px; color: var(--text3); margin-bottom: 2px; }
  .detail-item-value { font-size: 13px; font-weight: 500; }
  .msds-box {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 14px;
    font-size: 13px;
    line-height: 1.7;
  }
  .msds-row { display: flex; gap: 8px; padding: 5px 0; border-bottom: 1px solid var(--border); }
  .msds-row:last-child { border-bottom: none; }
  .msds-key { color: var(--text3); width: 110px; flex-shrink: 0; font-size: 12px; }
  .msds-val { font-size: 12px; }
  .warn-box {
    background: rgba(239,68,68,0.08);
    border: 1px solid rgba(239,68,68,0.2);
    border-radius: 10px;
    padding: 12px 14px;
    font-size: 12px;
    line-height: 1.8;
    color: #fca5a5;
  }
  .note-box {
    background: rgba(59,130,246,0.08);
    border: 1px solid rgba(59,130,246,0.2);
    border-radius: 10px;
    padding: 12px 14px;
    font-size: 12px;
    line-height: 1.8;
    color: #93c5fd;
  }

  /* QR */
  .qr-wrap {
    display: flex; flex-direction: column; align-items: center; gap: 14px;
    padding: 24px;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 12px;
  }
  #qr-container canvas, #qr-container img { border-radius: 8px; }
  .qr-label { font-size: 12px; color: var(--text2); text-align: center; }
  .qr-name { font-weight: 700; font-size: 15px; }

  /* EMPTY */
  .empty {
    text-align: center; padding: 60px 20px;
    color: var(--text3);
  }
  .empty-icon { font-size: 40px; margin-bottom: 12px; }
  .empty-text { font-size: 14px; }

  /* MOBILE NAV */
  .mobile-nav {
    display: none;
    position: fixed; bottom: 0; left: 0; right: 0;
    background: var(--surface);
    border-top: 1px solid var(--border);
    padding: 8px 0 env(safe-area-inset-bottom, 8px);
    z-index: 100;
  }
  @media(max-width:768px) {
    .mobile-nav { display: flex; justify-content: space-around; }
    body { padding-bottom: 64px; }
    .main { padding: 16px; }
  }
  .mobile-nav-item {
    display: flex; flex-direction: column; align-items: center; gap: 3px;
    padding: 6px 16px;
    background: none; border: none; cursor: pointer;
    color: var(--text3); font-size: 10px; font-family: inherit;
    transition: color 0.15s;
  }
  .mobile-nav-item.active { color: var(--accent); }
  .mobile-nav-icon { font-size: 20px; }

  /* PAGE */
  .page { display: none; }
  .page.active { display: block; }

  /* QR PAGE */
  .qr-print-card {
    background: #fff;
    color: #111;
    border-radius: 12px;
    padding: 20px;
    display: flex; align-items: center; gap: 16px;
    margin-bottom: 12px;
    border: 1px solid var(--border);
  }
  .qr-print-info h3 { font-size: 15px; font-weight: 700; margin-bottom: 4px; }
  .qr-print-info p { font-size: 12px; color: #555; }

  .tag { display: inline-block; padding: 2px 8px; border-radius: 4px; font-size: 11px; font-weight: 500; background: var(--surface2); color: var(--text2); margin-right: 4px; }

  /* scrollbar */
  ::-webkit-scrollbar { width: 6px; height: 6px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
</style>
</head>
<body>

<header>
  <div class="logo">
    <div class="logo-icon">⚗️</div>
    <span>ChemSafe<span style="color:var(--accent)">PSM</span></span>
  </div>
  <div class="header-right">
    <button class="btn btn-ghost btn-sm" onclick="openAddModal()">+ 물질 등록</button>
    <button class="btn btn-primary btn-sm" onclick="showPage('qr-page')">QR 인쇄</button>
  </div>
</header>

<div class="layout">
  <!-- SIDEBAR -->
  <nav class="sidebar">
    <div class="nav-label">메뉴</div>
    <button class="nav-item active" id="nav-dashboard" onclick="showPage('dashboard')">📊 &nbsp;대시보드</button>
    <button class="nav-item" id="nav-list" onclick="showPage('list')">🧪 &nbsp;물질 목록</button>
    <button class="nav-item" id="nav-qr-page" onclick="showPage('qr-page')">📷 &nbsp;QR 관리</button>
    <div class="nav-label" style="margin-top:8px;">위험등급</div>
    <button class="filter-btn" style="width:100%;margin-bottom:4px;text-align:left;" onclick="filterRisk(0)">전체 보기</button>
    <button class="filter-btn" style="width:100%;margin-bottom:4px;text-align:left;color:var(--red)" onclick="filterRisk(4)">🔴 GHS 4등급</button>
    <button class="filter-btn" style="width:100%;margin-bottom:4px;text-align:left;color:var(--accent)" onclick="filterRisk(3)">🟠 GHS 3등급</button>
    <button class="filter-btn" style="width:100%;margin-bottom:4px;text-align:left;color:var(--yellow)" onclick="filterRisk(2)">🟡 GHS 2등급</button>
    <button class="filter-btn" style="width:100%;margin-bottom:4px;text-align:left;color:var(--green)" onclick="filterRisk(1)">🟢 GHS 1등급</button>
  </nav>

  <main class="main">

    <!-- DASHBOARD -->
    <div class="page active" id="dashboard">
      <div class="section-header" style="margin-bottom:20px;">
        <div>
          <div class="section-title">화학물질 안전관리 현황</div>
          <div style="font-size:12px;color:var(--text3);margin-top:2px;" id="dash-date"></div>
        </div>
        <button class="btn btn-primary" onclick="openAddModal()">+ 물질 등록</button>
      </div>
      <div class="stats" id="stats-area"></div>
      <div class="section-header">
        <div class="section-title">최근 등록 물질</div>
        <button class="btn btn-ghost btn-sm" onclick="showPage('list')">전체 보기 →</button>
      </div>
      <div class="table-wrap">
        <table>
          <thead><tr>
            <th>물질명</th><th>위험등급</th><th>GHS</th><th>보관위치</th><th>담당자</th>
          </tr></thead>
          <tbody id="recent-tbody"></tbody>
        </table>
      </div>
    </div>

    <!-- LIST -->
    <div class="page" id="list">
      <div class="section-header">
        <div class="section-title">🧪 화학물질 목록</div>
        <button class="btn btn-primary" onclick="openAddModal()">+ 물질 등록</button>
      </div>
      <div class="toolbar">
        <div class="search-wrap">
          <span class="search-icon">🔍</span>
          <input type="text" placeholder="물질명, CAS번호 검색..." id="search-input" oninput="renderList()">
        </div>
        <button class="filter-btn" id="f-all" onclick="setFilter('all')" style="border-color:var(--accent);color:var(--accent)">전체</button>
        <button class="filter-btn" id="f-4" onclick="setFilter('4')">4등급</button>
        <button class="filter-btn" id="f-3" onclick="setFilter('3')">3등급</button>
        <button class="filter-btn" id="f-2" onclick="setFilter('2')">2등급</button>
        <button class="filter-btn" id="f-1" onclick="setFilter('1')">1등급</button>
      </div>
      <div class="table-wrap">
        <table>
          <thead><tr>
            <th>물질명</th><th>CAS No.</th><th>위험등급</th><th>GHS</th><th>보관위치</th><th>담당자</th><th>작업</th>
          </tr></thead>
          <tbody id="list-tbody"></tbody>
        </table>
      </div>
    </div>

    <!-- QR PAGE -->
    <div class="page" id="qr-page">
      <div class="section-header">
        <div class="section-title">📷 QR코드 관리</div>
        <button class="btn btn-primary" onclick="window.print()">🖨️ 인쇄</button>
      </div>
      <p style="font-size:13px;color:var(--text3);margin-bottom:20px;">각 화학물질 QR코드를 스캔하면 안전정보가 즉시 표시됩니다.</p>
      <div id="qr-list-area"></div>
    </div>

  </main>
</div>

<!-- MOBILE NAV -->
<nav class="mobile-nav">
  <button class="mobile-nav-item active" id="mnav-dashboard" onclick="showPage('dashboard')"><span class="mobile-nav-icon">📊</span>대시보드</button>
  <button class="mobile-nav-item" id="mnav-list" onclick="showPage('list')"><span class="mobile-nav-icon">🧪</span>목록</button>
  <button class="mobile-nav-item" id="mnav-qr-page" onclick="showPage('qr-page')"><span class="mobile-nav-icon">📷</span>QR</button>
  <button class="mobile-nav-item" onclick="openAddModal()"><span class="mobile-nav-icon">➕</span>등록</button>
</nav>

<!-- ADD/EDIT MODAL -->
<div class="modal-backdrop" id="add-modal">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title" id="add-modal-title">화학물질 등록</div>
      <button class="close-btn" onclick="closeAddModal()">✕</button>
    </div>
    <div class="modal-body">
      <div class="form-grid">
        <div class="form-group">
          <label class="form-label">물질명 *</label>
          <input class="form-input" id="f-name" placeholder="예) 에탄올">
        </div>
        <div class="form-group">
          <label class="form-label">CAS 번호</label>
          <input class="form-input" id="f-cas" placeholder="예) 64-17-5">
        </div>
        <div class="form-group">
          <label class="form-label">위험등급 *</label>
          <select class="form-select" id="f-risk">
            <option value="1">1등급 (낮음)</option>
            <option value="2">2등급 (보통)</option>
            <option value="3" selected>3등급 (높음)</option>
            <option value="4">4등급 (매우 높음)</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">보관위치</label>
          <input class="form-input" id="f-location" placeholder="예) B동 2층 화학창고">
        </div>
        <div class="form-group">
          <label class="form-label">담당자</label>
          <input class="form-input" id="f-manager" placeholder="담당자 이름">
        </div>
        <div class="form-group">
          <label class="form-label">최대 보유량</label>
          <input class="form-input" id="f-maxqty" placeholder="예) 200L">
        </div>

        <div class="form-group form-full">
          <label class="form-label">GHS 그림문자 선택</label>
          <div class="ghs-grid" id="ghs-checkboxes"></div>
        </div>

        <div class="form-group form-full">
          <label class="form-label">응급처치 방법</label>
          <textarea class="form-textarea" id="f-firstaid" placeholder="흡입 시, 피부 접촉 시, 눈 접촉 시 처치 방법..."></textarea>
        </div>
        <div class="form-group form-full">
          <label class="form-label">보관/취급 주의사항</label>
          <textarea class="form-textarea" id="f-storage" placeholder="보관 온도, 혼합 금지 물질, 환기 요건..."></textarea>
        </div>
        <div class="form-group form-full">
          <label class="form-label">개인보호장비 (PPE)</label>
          <input class="form-input" id="f-ppe" placeholder="예) 내화학성 장갑, 보안경, 방독면">
        </div>
        <div class="form-group form-full">
          <label class="form-label">비고</label>
          <textarea class="form-textarea" id="f-note" placeholder="추가 메모..."></textarea>
        </div>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-ghost" onclick="closeAddModal()">취소</button>
      <button class="btn btn-primary" onclick="saveChemical()">저장</button>
    </div>
  </div>
</div>

<!-- DETAIL MODAL -->
<div class="modal-backdrop" id="detail-modal">
  <div class="modal">
    <div class="modal-header">
      <div>
        <div class="modal-title" id="detail-name">-</div>
        <div style="font-size:12px;color:var(--text3);margin-top:2px;" id="detail-cas"></div>
      </div>
      <div style="display:flex;gap:8px;align-items:center;">
        <button class="btn btn-ghost btn-sm" onclick="editCurrent()">✏️ 수정</button>
        <button class="close-btn" onclick="closeDetailModal()">✕</button>
      </div>
    </div>
    <div class="modal-body" id="detail-body"></div>
  </div>
</div>

<!-- QR MODAL -->
<div class="modal-backdrop" id="qr-modal">
  <div class="modal" style="max-width:360px;">
    <div class="modal-header">
      <div class="modal-title">QR 코드</div>
      <button class="close-btn" onclick="closeQRModal()">✕</button>
    </div>
    <div class="modal-body">
      <div class="qr-wrap">
        <div id="qr-container"></div>
        <div class="qr-label">
          <div class="qr-name" id="qr-chem-name"></div>
          <div>스캔하면 안전정보를 확인할 수 있습니다</div>
        </div>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-primary" onclick="downloadQR()">⬇️ 다운로드</button>
    </div>
  </div>
</div>

<script>
// ==================== DATA ====================
const GHS_LIST = [
  { id:'explosive', icon:'💥', label:'폭발성' },
  { id:'flammable', icon:'🔥', label:'인화성' },
  { id:'oxidizing', icon:'🌡️', label:'산화성' },
  { id:'compressed', icon:'🪣', label:'고압가스' },
  { id:'corrosive', icon:'⚗️', label:'부식성' },
  { id:'toxic', icon:'☠️', label:'급성독성' },
  { id:'irritant', icon:'⚠️', label:'유해성' },
  { id:'health', icon:'🫁', label:'건강유해' },
  { id:'environ', icon:'🐟', label:'환경유해' },
];

let chemicals = JSON.parse(localStorage.getItem('chemsafe_data') || 'null') || [
  { id:1, name:'에탄올(Ethanol)', cas:'64-17-5', risk:2, ghs:['flammable','irritant'], location:'A동 1층 약품창고', manager:'김안전', maxqty:'500L', firstaid:'흡입 시 신선한 공기로 이동. 피부 접촉 시 비누와 물로 세척. 눈 접촉 시 15분 이상 세척 후 의사 진찰.', storage:'화기로부터 격리 보관. 서늘하고 건조한 곳에 밀폐 보관. 정전기 방지 접지 필요.', ppe:'내화학성 장갑, 보안경, 실험복', note:'', created: Date.now()-86400000*5 },
  { id:2, name:'황산(Sulfuric Acid)', cas:'7664-93-9', risk:4, ghs:['corrosive','toxic'], location:'B동 화학창고', manager:'이화학', maxqty:'100L', firstaid:'즉시 물로 최소 30분 세척. 흡입 시 즉시 신선한 공기로 이동. 반드시 의사 진찰.', storage:'금속, 가연물과 격리. 밀폐용기 냉암소 보관. 알칼리류와 혼합 금지.', ppe:'내산성 장갑, 방독면, 보안경, 앞치마', note:'PSM 관리 물질', created: Date.now()-86400000*3 },
  { id:3, name:'아세톤(Acetone)', cas:'67-64-1', risk:3, ghs:['flammable','irritant'], location:'A동 2층 실험실', manager:'박공정', maxqty:'200L', firstaid:'흡입 시 신선한 공기로 이동. 눈 접촉 시 물로 15분 이상 세척. 피부 자극 지속 시 의사 진찰.', storage:'점화원과 격리. 30℃ 이하 냉암소 보관. 산화제 근처 보관 금지.', ppe:'내화학성 장갑, 보안경, 방독면(유기증기)', note:'', created: Date.now()-86400000*1 },
  { id:4, name:'질소(Nitrogen)', cas:'7727-37-9', risk:1, ghs:['compressed'], location:'C동 가스실', manager:'최설비', maxqty:'50kg', firstaid:'질식 증상 시 신선한 공기 공급, 심폐소생술 시행, 즉시 의사 진찰.', storage:'직사광선 피해 환기 좋은 곳 보관. 열원으로부터 격리. 전도 방지 조치.', ppe:'보안경, 단열장갑', note:'불활성 가스 질식 위험', created: Date.now()-86400000*2 },
];
let editingId = null;
let currentFilter = 'all';
let currentDetailId = null;

function save() { localStorage.setItem('chemsafe_data', JSON.stringify(chemicals)); }
function getById(id) { return chemicals.find(c => c.id == id); }

// ==================== PAGE ====================
function showPage(name) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.getElementById(name).classList.add('active');
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  const nav = document.getElementById('nav-'+name);
  if(nav) nav.classList.add('active');
  document.querySelectorAll('.mobile-nav-item').forEach(n => n.classList.remove('active'));
  const mnav = document.getElementById('mnav-'+name);
  if(mnav) mnav.classList.add('active');
  if(name==='dashboard') renderDashboard();
  if(name==='list') renderList();
  if(name==='qr-page') renderQRList();
}

// ==================== DASHBOARD ====================
function renderDashboard() {
  const d = new Date();
  document.getElementById('dash-date').textContent = d.toLocaleDateString('ko-KR', {year:'numeric',month:'long',day:'numeric',weekday:'long'});

  const total = chemicals.length;
  const byRisk = [0,0,0,0,0];
  chemicals.forEach(c => byRisk[c.risk]++);

  document.getElementById('stats-area').innerHTML = `
    <div class="stat-card"><div class="stat-label">전체 등록 물질</div><div class="stat-value" style="color:var(--blue)">${total}</div><div class="stat-sub">종</div></div>
    <div class="stat-card"><div class="stat-label">4등급 (매우위험)</div><div class="stat-value" style="color:var(--red)">${byRisk[4]}</div><div class="stat-sub">종</div></div>
    <div class="stat-card"><div class="stat-label">3등급 (위험)</div><div class="stat-value" style="color:var(--accent)">${byRisk[3]}</div><div class="stat-sub">종</div></div>
    <div class="stat-card"><div class="stat-label">2등급 (주의)</div><div class="stat-value" style="color:var(--yellow)">${byRisk[2]}</div><div class="stat-sub">종</div></div>
    <div class="stat-card"><div class="stat-label">1등급 (낮음)</div><div class="stat-value" style="color:var(--green)">${byRisk[1]}</div><div class="stat-sub">종</div></div>
  `;

  const recent = [...chemicals].sort((a,b)=>b.created-a.created).slice(0,5);
  const tbody = document.getElementById('recent-tbody');
  if(!recent.length) { tbody.innerHTML = '<tr><td colspan="5"><div class="empty"><div class="empty-icon">🧪</div><div class="empty-text">등록된 물질이 없습니다</div></div></td></tr>'; return; }
  tbody.innerHTML = recent.map(c => `
    <tr onclick="openDetail(${c.id})">
      <td><strong>${c.name}</strong></td>
      <td>${riskBadge(c.risk)}</td>
      <td><div class="ghs-icons">${(c.ghs||[]).map(g=>ghsIcon(g)).join('')}</div></td>
      <td style="color:var(--text2)">${c.location||'-'}</td>
      <td style="color:var(--text2)">${c.manager||'-'}</td>
    </tr>
  `).join('');
}

// ==================== LIST ====================
function setFilter(v) {
  currentFilter = v;
  document.querySelectorAll('[id^="f-"]').forEach(b => b.classList.remove('active'));
  document.getElementById('f-'+v).classList.add('active');
  renderList();
}
function filterRisk(r) {
  showPage('list');
  setFilter(r===0?'all':String(r));
}
function renderList() {
  const q = (document.getElementById('search-input')?.value||'').toLowerCase();
  let filtered = chemicals.filter(c => {
    const matchQ = !q || c.name.toLowerCase().includes(q) || (c.cas||'').includes(q);
    const matchR = currentFilter==='all' || String(c.risk)===currentFilter;
    return matchQ && matchR;
  });
  filtered.sort((a,b) => b.risk - a.risk);
  const tbody = document.getElementById('list-tbody');
  if(!filtered.length) {
    tbody.innerHTML = '<tr><td colspan="7"><div class="empty"><div class="empty-icon">🔍</div><div class="empty-text">검색 결과가 없습니다</div></div></td></tr>';
    return;
  }
  tbody.innerHTML = filtered.map(c => `
    <tr onclick="openDetail(${c.id})">
      <td><strong>${c.name}</strong></td>
      <td style="font-family:monospace;font-size:12px;color:var(--text3)">${c.cas||'-'}</td>
      <td>${riskBadge(c.risk)}</td>
      <td><div class="ghs-icons">${(c.ghs||[]).map(g=>ghsIcon(g)).join('')}</div></td>
      <td style="color:var(--text2);font-size:12px">${c.location||'-'}</td>
      <td style="color:var(--text2);font-size:12px">${c.manager||'-'}</td>
      <td onclick="event.stopPropagation()">
        <div style="display:flex;gap:4px">
          <button class="btn btn-ghost btn-sm" onclick="openQRModal(${c.id})">QR</button>
          <button class="btn btn-ghost btn-sm" onclick="openEdit(${c.id})">✏️</button>
          <button class="btn btn-danger btn-sm" onclick="deleteChemical(${c.id})">🗑</button>
        </div>
      </td>
    </tr>
  `).join('');
}

// ==================== ADD/EDIT ====================
function buildGHSCheckboxes() {
  document.getElementById('ghs-checkboxes').innerHTML = GHS_LIST.map(g => `
    <label class="ghs-check" id="ghsc-${g.id}" onclick="toggleGHS('${g.id}')">
      <input type="checkbox" id="ghsi-${g.id}">
      <span class="ghs-check-icon">${g.icon}</span>
      <span>${g.label}</span>
    </label>
  `).join('');
}
function toggleGHS(id) {
  const el = document.getElementById('ghsc-'+id);
  el.classList.toggle('checked');
}
function getSelectedGHS() {
  return GHS_LIST.filter(g => document.getElementById('ghsc-'+g.id)?.classList.contains('checked')).map(g=>g.id);
}
function setGHSSelected(ids) {
  GHS_LIST.forEach(g => {
    const el = document.getElementById('ghsc-'+g.id);
    if(el) { el.classList.toggle('checked', ids.includes(g.id)); }
  });
}
function openAddModal() {
  editingId = null;
  document.getElementById('add-modal-title').textContent = '화학물질 등록';
  ['name','cas','location','manager','maxqty','firstaid','storage','ppe','note'].forEach(k => document.getElementById('f-'+k).value='');
  document.getElementById('f-risk').value = '3';
  buildGHSCheckboxes();
  document.getElementById('add-modal').classList.add('open');
}
function openEdit(id) {
  const c = getById(id);
  if(!c) return;
  editingId = id;
  document.getElementById('add-modal-title').textContent = '화학물질 수정';
  document.getElementById('f-name').value = c.name;
  document.getElementById('f-cas').value = c.cas||'';
  document.getElementById('f-risk').value = c.risk;
  document.getElementById('f-location').value = c.location||'';
  document.getElementById('f-manager').value = c.manager||'';
  document.getElementById('f-maxqty').value = c.maxqty||'';
  document.getElementById('f-firstaid').value = c.firstaid||'';
  document.getElementById('f-storage').value = c.storage||'';
  document.getElementById('f-ppe').value = c.ppe||'';
  document.getElementById('f-note').value = c.note||'';
  buildGHSCheckboxes();
  setGHSSelected(c.ghs||[]);
  document.getElementById('add-modal').classList.add('open');
}
function editCurrent() { closeDetailModal(); if(currentDetailId) openEdit(currentDetailId); }
function closeAddModal() { document.getElementById('add-modal').classList.remove('open'); }
function saveChemical() {
  const name = document.getElementById('f-name').value.trim();
  if(!name) { alert('물질명을 입력해주세요'); return; }
  const data = {
    name, cas: document.getElementById('f-cas').value.trim(),
    risk: parseInt(document.getElementById('f-risk').value),
    location: document.getElementById('f-location').value.trim(),
    manager: document.getElementById('f-manager').value.trim(),
    maxqty: document.getElementById('f-maxqty').value.trim(),
    firstaid: document.getElementById('f-firstaid').value.trim(),
    storage: document.getElementById('f-storage').value.trim(),
    ppe: document.getElementById('f-ppe').value.trim(),
    note: document.getElementById('f-note').value.trim(),
    ghs: getSelectedGHS(),
  };
  if(editingId) {
    const idx = chemicals.findIndex(c=>c.id==editingId);
    chemicals[idx] = {...chemicals[idx], ...data};
  } else {
    data.id = Date.now();
    data.created = Date.now();
    chemicals.unshift(data);
  }
  save();
  closeAddModal();
  renderDashboard();
  renderList();
}
function deleteChemical(id) {
  if(!confirm('삭제하시겠습니까?')) return;
  chemicals = chemicals.filter(c=>c.id!=id);
  save();
  renderList();
  renderDashboard();
}

// ==================== DETAIL ====================
function openDetail(id) {
  const c = getById(id);
  if(!c) return;
  currentDetailId = id;
  document.getElementById('detail-name').textContent = c.name;
  document.getElementById('detail-cas').textContent = c.cas ? 'CAS No. '+c.cas : '';
  const ghsHtml = (c.ghs||[]).map(g=>{
    const info = GHS_LIST.find(x=>x.id===g);
    return info ? `<div class="ghs-icon" style="width:36px;height:36px;font-size:20px" title="${info.label}">${info.icon}</div>` : '';
  }).join('');
  document.getElementById('detail-body').innerHTML = `
    <div class="detail-section">
      <div class="detail-section-title">기본 정보</div>
      <div class="detail-grid">
        <div class="detail-item"><div class="detail-item-label">위험등급</div><div class="detail-item-value">${riskBadge(c.risk)} ${riskLabel(c.risk)}</div></div>
        <div class="detail-item"><div class="detail-item-label">보관위치</div><div class="detail-item-value">${c.location||'-'}</div></div>
        <div class="detail-item"><div class="detail-item-label">담당자</div><div class="detail-item-value">${c.manager||'-'}</div></div>
        <div class="detail-item"><div class="detail-item-label">최대 보유량</div><div class="detail-item-value">${c.maxqty||'-'}</div></div>
      </div>
    </div>
    ${ghsHtml ? `<div class="detail-section"><div class="detail-section-title">GHS 그림문자</div><div class="ghs-icons">${ghsHtml}</div></div>` : ''}
    ${c.ppe ? `<div class="detail-section"><div class="detail-section-title">개인보호장비 (PPE)</div><div class="note-box">${c.ppe}</div></div>` : ''}
    ${c.firstaid ? `<div class="detail-section"><div class="detail-section-title">응급처치 방법</div><div class="warn-box">${c.firstaid.replace(/\n/g,'<br>')}</div></div>` : ''}
    ${c.storage ? `<div class="detail-section"><div class="detail-section-title">보관·취급 주의사항</div><div class="msds-box">${c.storage.replace(/\n/g,'<br>')}</div></div>` : ''}
    ${c.note ? `<div class="detail-section"><div class="detail-section-title">비고</div><div class="msds-box">${c.note}</div></div>` : ''}
    <div style="margin-top:16px;display:flex;gap:8px">
      <button class="btn btn-primary" onclick="openQRModal(${c.id});closeDetailModal()">📷 QR 코드 생성</button>
      <button class="btn btn-ghost" onclick="editCurrent()">✏️ 수정</button>
    </div>
  `;
  document.getElementById('detail-modal').classList.add('open');
}
function closeDetailModal() { document.getElementById('detail-modal').classList.remove('open'); }

// ==================== QR ====================
let qrInstance = null;
function openQRModal(id) {
  const c = getById(id);
  if(!c) return;
  document.getElementById('qr-chem-name').textContent = c.name;
  const container = document.getElementById('qr-container');
  container.innerHTML = '';
  const qrData = JSON.stringify({
    name: c.name, cas: c.cas, risk: c.risk,
    location: c.location, manager: c.manager,
    ghs: c.ghs, ppe: c.ppe,
    firstaid: c.firstaid, storage: c.storage
  });
  qrInstance = new QRCode(container, {
    text: qrData, width: 200, height: 200,
    colorDark: '#000000', colorLight: '#ffffff',
    correctLevel: QRCode.CorrectLevel.M
  });
  document.getElementById('qr-modal').classList.add('open');
}
function closeQRModal() { document.getElementById('qr-modal').classList.remove('open'); }
function downloadQR() {
  const canvas = document.querySelector('#qr-container canvas');
  if(!canvas) return;
  const a = document.createElement('a');
  a.href = canvas.toDataURL();
  a.download = 'qr_'+document.getElementById('qr-chem-name').textContent+'.png';
  a.click();
}

function renderQRList() {
  const area = document.getElementById('qr-list-area');
  if(!chemicals.length) { area.innerHTML = '<div class="empty"><div class="empty-icon">📷</div><div class="empty-text">등록된 물질이 없습니다</div></div>'; return; }
  area.innerHTML = chemicals.map(c => `
    <div style="background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:16px;margin-bottom:10px;display:flex;align-items:center;gap:16px;flex-wrap:wrap">
      <div id="qr-mini-${c.id}" style="flex-shrink:0"></div>
      <div style="flex:1;min-width:180px">
        <div style="font-weight:700;font-size:15px;margin-bottom:4px">${c.name}</div>
        <div style="font-size:12px;color:var(--text3);margin-bottom:6px">${c.cas?'CAS: '+c.cas+' · ':''} ${c.location||''}</div>
        <div style="display:flex;gap:6px;flex-wrap:wrap;align-items:center">
          ${riskBadge(c.risk)}
          <div class="ghs-icons">${(c.ghs||[]).map(g=>ghsIcon(g)).join('')}</div>
        </div>
      </div>
      <div style="display:flex;gap:6px;flex-wrap:wrap">
        <button class="btn btn-primary btn-sm" onclick="openQRModal(${c.id})">크게 보기</button>
        <button class="btn btn-ghost btn-sm" onclick="openDetail(${c.id})">상세 정보</button>
      </div>
    </div>
  `).join('');
  // render mini QRs
  chemicals.forEach(c => {
    const el = document.getElementById('qr-mini-'+c.id);
    if(!el) return;
    try {
      new QRCode(el, {
        text: c.name + (c.cas?' CAS:'+c.cas:'') + ' 위험등급:'+c.risk,
        width: 64, height: 64,
        colorDark:'#000', colorLight:'#fff',
        correctLevel: QRCode.CorrectLevel.L
      });
    } catch(e){}
  });
}

// ==================== HELPERS ====================
function riskBadge(r) {
  const map = {1:'badge-1',2:'badge-2',3:'badge-3',4:'badge-4'};
  const label = {1:'1등급',2:'2등급',3:'3등급',4:'4등급'};
  return `<span class="badge ${map[r]||''}">${label[r]||r+'등급'}</span>`;
}
function riskLabel(r) {
  return {1:'(낮음)',2:'(주의)',3:'(높음)',4:'(매우 높음)'}[r]||'';
}
function ghsIcon(id) {
  const info = GHS_LIST.find(g=>g.id===id);
  return info ? `<div class="ghs-icon" title="${info.label}">${info.icon}</div>` : '';
}

// ==================== INIT ====================
buildGHSCheckboxes();
renderDashboard();
document.getElementById('f-all').classList.add('active');

// close modals on backdrop click
['add-modal','detail-modal','qr-modal'].forEach(id => {
  document.getElementById(id).addEventListener('click', function(e){
    if(e.target===this) {
      if(id==='add-modal') closeAddModal();
      else if(id==='detail-modal') closeDetailModal();
      else closeQRModal();
    }
  });
});
</script>
</body>
</html>
